{
  "manifest_version": 3,
  "name": "RenderScope",
  "version": "1.0.0",
  "description": "RenderScope — Performance profiler for Three.js and WebGL applications. Root-cause analysis, scene inspection, shader profiling.",
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "devtools_page": "devtools/devtools.html",

  "background": {
    "service_worker": "background/bridge.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/profiler.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],

  "host_permissions": ["<all_urls>"]
}
